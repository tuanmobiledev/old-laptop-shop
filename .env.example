# Web host port when running docker compose directly.
# Dokploy should route laprevive-web to container port 80.
APP_PORT=18080

# PostgreSQL service. Change POSTGRES_PASSWORD in Dokploy/production.
POSTGRES_DB=laprevive
POSTGRES_USER=laprevive
POSTGRES_PASSWORD=change_this_strong_password
DB_PORT=15432

# Google Analytics 4 measurement ID. Example: G-XXXXXXXXXX
VITE_GA4_MEASUREMENT_ID=G-F3JDDL0G2P

# Admin authentication token — change this in production.
VITE_ADMIN_TOKEN=oscar-admin-2026
